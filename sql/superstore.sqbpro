<?xml version="1.0" encoding="UTF-8"?><sqlb_project><db path="C:/Users/HP/OneDrive/Desktop/dataanalyst/retail_project/sql/superstore.db" readonly="0" foreign_keys="1" case_sensitive_like="0" temp_store="0" wal_autocheckpoint="1000" synchronous="2"/><attached/><window><main_tabs open="structure browser pragmas query" current="3"/></window><tab_structure><column_width id="0" width="300"/><column_width id="1" width="0"/><column_width id="2" width="100"/><column_width id="3" width="2578"/><column_width id="4" width="0"/><expanded_item id="0" parent="1"/><expanded_item id="1" parent="1"/><expanded_item id="2" parent="1"/><expanded_item id="3" parent="1"/></tab_structure><tab_browse><table title="superstore" custom_title="0" dock_id="4" table="4,10:mainsuperstore"/><dock_state state=""/><default_encoding codec=""/><browse_table_settings><table schema="main" name="superstore" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="54"/><column index="2" value="117"/><column index="3" value="156"/><column index="4" value="156"/><column index="5" value="117"/><column index="6" value="82"/><column index="7" value="163"/><column index="8" value="93"/><column index="9" value="109"/><column index="10" value="132"/><column index="11" value="117"/><column index="12" value="77"/><column index="13" value="62"/><column index="14" value="124"/><column index="15" value="124"/><column index="16" value="93"/><column index="17" value="300"/><column index="18" value="78"/><column index="19" value="56"/><column index="20" value="57"/><column index="21" value="85"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1*">-- Query 1.1: How many rows do we have?
SELECT COUNT(*) AS Total_Rows FROM superstore;
-- Expected: 9994
-- Query 1.2: Check for NULL values in every important column
SELECT
    SUM(CASE WHEN Sales        IS NULL THEN 1 ELSE 0 END) AS Null_Sales,
    SUM(CASE WHEN Profit       IS NULL THEN 1 ELSE 0 END) AS Null_Profit,
    SUM(CASE WHEN Quantity     IS NULL THEN 1 ELSE 0 END) AS Null_Quantity,
    SUM(CASE WHEN Discount     IS NULL THEN 1 ELSE 0 END) AS Null_Discount,
    SUM(CASE WHEN Category     IS NULL THEN 1 ELSE 0 END) AS Null_Category,
    SUM(CASE WHEN Region       IS NULL THEN 1 ELSE 0 END) AS Null_Region,
    SUM(CASE WHEN Order_Date   IS NULL THEN 1 ELSE 0 END) AS Null_Order_Date,
    SUM(CASE WHEN Customer_ID  IS NULL THEN 1 ELSE 0 END) AS Null_Customer_ID
FROM superstore;
-- All values should be 0 (this dataset is clean)
-- Query 1.3: Date range of the data
SELECT
    MIN(STRFTIME('%Y-%m-%d', Order_Date)) AS Earliest_Order,
    MAX(STRFTIME('%Y-%m-%d', Order_Date)) AS Latest_Order,
    (CAST(STRFTIME('%Y', MAX(Order_Date)) AS INT) -
     CAST(STRFTIME('%Y', MIN(Order_Date)) AS INT) + 1) AS Years_Of_Data
FROM superstore;
-- Expected: 2014-01-03 to 2017-12-30 (4 years)
-- Query 1.4: All unique Categories and Sub-Categories
SELECT
    Category,
    Sub_Category,
    COUNT(*) AS Total_Rows
FROM superstore
GROUP BY Category, Sub_Category
ORDER BY Category, Sub_Category;
-- Should show 3 categories, 17 sub-categories
-- Query 1.5: All four regions
SELECT
    Region,
    COUNT(DISTINCT State)       AS States_Covered,
    COUNT(DISTINCT Customer_ID) AS Unique_Customers,
    COUNT(DISTINCT Order_ID)    AS Total_Orders
FROM superstore
GROUP BY Region
ORDER BY Total_Orders DESC;
-- Query 2.1: Profit margin by Category (high level)
SELECT
    Category,
    COUNT(*)                                            AS Num_Orders,
    ROUND(SUM(Sales), 2)                               AS Total_Sales,
    ROUND(SUM(Profit), 2)                              AS Total_Profit,
    SUM(Quantity)                                      AS Units_Sold,
    ROUND(AVG(Discount) * 100, 2)                     AS Avg_Discount_Pct,
    ROUND(SUM(Profit) * 100.0 / SUM(Sales), 2)        AS Profit_Margin_Pct
FROM superstore
GROUP BY Category
ORDER BY Profit_Margin_Pct DESC;

-- 📌 Expected result:
-- Technology:     17.4% margin  ← Best
-- Office Supplies: 17.0% margin
-- Furniture:        2.5% margin ← Worst
-- Query 2.2: Profit margin by Sub-Category (sorted worst → best)
SELECT
    Category,
    Sub_Category,
    COUNT(*)                                           AS Num_Orders,
    ROUND(SUM(Sales), 2)                              AS Total_Sales,
    ROUND(SUM(Profit), 2)                             AS Total_Profit,
    SUM(Quantity)                                     AS Units_Sold,
    ROUND(AVG(Discount) * 100, 2)                    AS Avg_Discount_Pct,
    ROUND(SUM(Profit) * 100.0 / SUM(Sales), 2)       AS Profit_Margin_Pct
FROM superstore
GROUP BY Category, Sub_Category
ORDER BY Profit_Margin_Pct ASC;

-- 📌 Tables and Bookcases will show negative margins
-- Query 2.2: Profit margin by Sub-Category (sorted worst → best)
SELECT
    Category,
    Sub_Category,
    COUNT(*)                                           AS Num_Orders,
    ROUND(SUM(Sales), 2)                              AS Total_Sales,
    ROUND(SUM(Profit), 2)                             AS Total_Profit,
    SUM(Quantity)                                     AS Units_Sold,
    ROUND(AVG(Discount) * 100, 2)                    AS Avg_Discount_Pct,
    ROUND(SUM(Profit) * 100.0 / SUM(Sales), 2)       AS Profit_Margin_Pct
FROM superstore
GROUP BY Category, Sub_Category
ORDER BY Profit_Margin_Pct ASC;

-- 📌 Tables and Bookcases will show negative margins
-- Query 2.3: LOSS-MAKING sub-categories only
SELECT
    Category,
    Sub_Category,
    ROUND(SUM(Sales), 2)                              AS Total_Sales,
    ROUND(SUM(Profit), 2)                             AS Total_Profit,
    ROUND(SUM(Profit) * 100.0 / SUM(Sales), 2)       AS Profit_Margin_Pct,
    ROUND(AVG(Discount) * 100, 2)                    AS Avg_Discount_Pct,
    COUNT(*)                                          AS Num_Orders
FROM superstore
GROUP BY Category, Sub_Category
HAVING SUM(Profit) &lt; 0
ORDER BY Total_Profit ASC;

-- 📌 These 3 sub-categories are draining profit:
--    Tables:    -$17,725
--    Bookcases:  -$3,472
--    Supplies:   -$1,189
-- Query 2.4: Top 10 most profitable products
SELECT
    Product_Name,
    Category,
    Sub_Category,
    SUM(Quantity)                AS Units_Sold,
    ROUND(SUM(Sales), 2)         AS Total_Sales,
    ROUND(SUM(Profit), 2)        AS Total_Profit,
    ROUND(SUM(Profit) * 100.0 / SUM(Sales), 2) AS Margin_Pct
FROM superstore
GROUP BY Product_Name, Category, Sub_Category
ORDER BY Total_Profit DESC
LIMIT 10;
-- Query 2.5: Top 10 worst (loss-making) products
SELECT
    Product_Name,
    Category,
    Sub_Category,
    SUM(Quantity)                AS Units_Sold,
    ROUND(SUM(Sales), 2)         AS Total_Sales,
    ROUND(SUM(Profit), 2)        AS Total_Profit,
    ROUND(AVG(Discount) * 100, 2) AS Avg_Discount_Pct
FROM superstore
GROUP BY Product_Name, Category, Sub_Category
ORDER BY Total_Profit ASC
LIMIT 10;
-- Query 3.1: How discount levels affect profit
-- This is a KEY insight query
SELECT
    CASE
        WHEN Discount = 0         THEN 'A: 0% (No Discount)'
        WHEN Discount &lt;= 0.10     THEN 'B: 1% – 10%'
        WHEN Discount &lt;= 0.20     THEN 'C: 11% – 20%'
        WHEN Discount &lt;= 0.30     THEN 'D: 21% – 30%'
        ELSE                           'E: 31% and above'
    END AS Discount_Bucket,
    COUNT(*)                     AS Num_Orders,
    ROUND(AVG(Profit), 2)        AS Avg_Profit_Per_Order,
    ROUND(SUM(Profit), 2)        AS Total_Profit,
    ROUND(AVG(Sales), 2)         AS Avg_Sales_Per_Order
FROM superstore
GROUP BY Discount_Bucket
ORDER BY Discount_Bucket;

-- 📌 You will see profit drops drastically above 20% discount
-- Query 3.2: Discount vs profit broken down by Category
SELECT
    Category,
    CASE
        WHEN Discount = 0     THEN '0%'
        WHEN Discount &lt;= 0.20 THEN '1-20%'
        ELSE '20%+'
    END AS Discount_Group,
    COUNT(*)                  AS Orders,
    ROUND(AVG(Profit), 2)     AS Avg_Profit
FROM superstore
GROUP BY Category, Discount_Group
ORDER BY Category, Discount_Group;
-- Query 3.3: Which sub-categories get the most discounts?
SELECT
    Sub_Category,
    ROUND(AVG(Discount) * 100, 2)   AS Avg_Discount_Pct,
    ROUND(MIN(Discount) * 100, 2)   AS Min_Discount_Pct,
    ROUND(MAX(Discount) * 100, 2)   AS Max_Discount_Pct,
    ROUND(SUM(Profit), 2)           AS Total_Profit
FROM superstore
GROUP BY Sub_Category
ORDER BY Avg_Discount_Pct DESC;
-- Query 3.4: Orders where discount made profit go negative
SELECT
    Category,
    Sub_Category,
    ROUND(Sales, 2)       AS Sales,
    ROUND(Profit, 2)      AS Profit,
    Discount,
    Quantity
FROM superstore
WHERE Profit &lt; 0
  AND Discount &gt; 0
ORDER BY Profit ASC
LIMIT 20;
-- Query 4.1: Revenue and profit per unit (turnover value proxy)
-- Low profit per unit + high discount = inventory problem
SELECT
    Sub_Category,
    ROUND(SUM(Sales), 2)                             AS Total_Sales,
    SUM(Quantity)                                    AS Total_Units_Sold,
    ROUND(SUM(Sales)   * 1.0 / SUM(Quantity), 2)    AS Revenue_Per_Unit,
    ROUND(SUM(Profit)  * 1.0 / SUM(Quantity), 2)    AS Profit_Per_Unit,
    ROUND(AVG(Discount) * 100, 2)                   AS Avg_Discount_Pct
FROM superstore
GROUP BY Sub_Category
ORDER BY Profit_Per_Unit ASC;

-- 📌 Tables show NEGATIVE profit per unit
-- 📌 Copiers show highest profit per unit
-- Query 4.2: Slow-moving products
-- Definition: sold ≤ 5 units total AND made a loss
SELECT
    Product_Name,
    Sub_Category,
    SUM(Quantity)               AS Total_Units_Sold,
    COUNT(*)                    AS Num_Transactions,
    ROUND(SUM(Profit), 2)       AS Total_Profit,
    ROUND(AVG(Discount)*100, 2) AS Avg_Discount_Pct
FROM superstore
GROUP BY Product_Name, Sub_Category
HAVING SUM(Quantity) &lt;= 5
   AND SUM(Profit) &lt; 0
ORDER BY Total_Profit ASC
LIMIT 20;
-- Query 4.3: Overstocked risk — high quantity sold but still losing money
SELECT
    Product_Name,
    Sub_Category,
    SUM(Quantity)               AS Total_Units_Sold,
    ROUND(SUM(Profit), 2)       AS Total_Profit,
    ROUND(AVG(Discount)*100, 2) AS Avg_Discount_Pct
FROM superstore
GROUP BY Product_Name, Sub_Category
HAVING SUM(Quantity) &gt; 20
   AND SUM(Profit) &lt; 0
ORDER BY Total_Profit ASC;

-- These items are sold IN BULK but still lose money — classic overstock issue
-- Query 5.1: Monthly sales and profit (all years combined)
SELECT
    STRFTIME('%m', Order_Date)         AS Month_Num,
    CASE STRFTIME('%m', Order_Date)
        WHEN '01' THEN 'January'
        WHEN '02' THEN 'February'
        WHEN '03' THEN 'March'
        WHEN '04' THEN 'April'
        WHEN '05' THEN 'May'
        WHEN '06' THEN 'June'
        WHEN '07' THEN 'July'
        WHEN '08' THEN 'August'
        WHEN '09' THEN 'September'
        WHEN '10' THEN 'October'
        WHEN '11' THEN 'November'
        WHEN '12' THEN 'December'
    END AS Month_Name,
    COUNT(DISTINCT Order_ID)           AS Total_Orders,
    ROUND(SUM(Sales), 2)               AS Total_Sales,
    ROUND(SUM(Profit), 2)              AS Total_Profit,
    ROUND(AVG(Sales), 2)               AS Avg_Order_Value
FROM superstore
GROUP BY Month_Num
ORDER BY Month_Num;

-- 📌 November and December typically peak (holiday season)
-- Query 5.2: Year-by-year growth
SELECT
    STRFTIME('%Y', Order_Date)         AS Year,
    COUNT(DISTINCT Order_ID)           AS Total_Orders,
    ROUND(SUM(Sales), 2)               AS Total_Sales,
    ROUND(SUM(Profit), 2)              AS Total_Profit,
    ROUND(SUM(Profit)*100.0/SUM(Sales),2) AS Margin_Pct
FROM superstore
GROUP BY Year
ORDER BY Year;
-- Query 5.3: Quarterly breakdown by Category
SELECT
    STRFTIME('%Y', Order_Date)  AS Year,
    CASE
        WHEN CAST(STRFTIME('%m', Order_Date) AS INT) BETWEEN 1 AND 3  THEN 'Q1 (Jan-Mar)'
        WHEN CAST(STRFTIME('%m', Order_Date) AS INT) BETWEEN 4 AND 6  THEN 'Q2 (Apr-Jun)'
        WHEN CAST(STRFTIME('%m', Order_Date) AS INT) BETWEEN 7 AND 9  THEN 'Q3 (Jul-Sep)'
        ELSE                                                                'Q4 (Oct-Dec)'
    END AS Quarter,
    Category,
    ROUND(SUM(Sales), 2)        AS Total_Sales,
    ROUND(SUM(Profit), 2)       AS Total_Profit,
    COUNT(DISTINCT Order_ID)    AS Total_Orders
FROM superstore
GROUP BY Year, Quarter, Category
ORDER BY Year, Quarter, Category;
-- Query 5.4: Best and worst performing months for each category
SELECT
    Category,
    STRFTIME('%m', Order_Date)  AS Month,
    ROUND(AVG(Profit), 2)       AS Avg_Monthly_Profit
FROM superstore
GROUP BY Category, Month
ORDER BY Category, Avg_Monthly_Profit DESC;
-- Query 6.1: Overall regional performance
SELECT
    Region,
    COUNT(DISTINCT Customer_ID)                     AS Unique_Customers,
    COUNT(DISTINCT Order_ID)                        AS Total_Orders,
    ROUND(SUM(Sales), 2)                            AS Total_Sales,
    ROUND(SUM(Profit), 2)                           AS Total_Profit,
    ROUND(SUM(Profit) * 100.0 / SUM(Sales), 2)     AS Profit_Margin_Pct,
    ROUND(AVG(Discount) * 100, 2)                  AS Avg_Discount_Pct
FROM superstore
GROUP BY Region
ORDER BY Profit_Margin_Pct DESC;
-- Query 6.2: Region × Category cross-analysis
SELECT
    Region,
    Category,
    ROUND(SUM(Sales), 2)                            AS Total_Sales,
    ROUND(SUM(Profit), 2)                           AS Total_Profit,
    ROUND(SUM(Profit) * 100.0 / SUM(Sales), 2)     AS Margin_Pct,
    ROUND(AVG(Discount) * 100, 2)                  AS Avg_Discount_Pct
FROM superstore
GROUP BY Region, Category
ORDER BY Region, Margin_Pct DESC;
-- Query 6.3: Top 10 best-performing states
SELECT
    State,
    Region,
    COUNT(DISTINCT Order_ID)     AS Total_Orders,
    ROUND(SUM(Sales), 2)         AS Total_Sales,
    ROUND(SUM(Profit), 2)        AS Total_Profit
FROM superstore
GROUP BY State, Region
ORDER BY Total_Profit DESC
LIMIT 10;
-- Query 6.4: Bottom 10 worst-performing states (biggest losses)
SELECT
    State,
    Region,
    COUNT(DISTINCT Order_ID)     AS Total_Orders,
    ROUND(SUM(Sales), 2)         AS Total_Sales,
    ROUND(SUM(Profit), 2)        AS Total_Profit,
    ROUND(AVG(Discount)*100, 2)  AS Avg_Discount_Pct
FROM superstore
GROUP BY State, Region
ORDER BY Total_Profit ASC
LIMIT 10;
-- Query 6.5: Region × Sub-Category (find which combos lose money)
SELECT
    Region,
    Sub_Category,
    ROUND(SUM(Sales), 2)                        AS Total_Sales,
    ROUND(SUM(Profit), 2)                       AS Total_Profit,
    ROUND(SUM(Profit)*100.0/SUM(Sales), 2)      AS Margin_Pct
FROM superstore
GROUP BY Region, Sub_Category
HAVING SUM(Profit) &lt; 0
ORDER BY Total_Profit ASC;
-- Query 7.1: Consumer vs Corporate vs Home Office
SELECT
    Segment,
    COUNT(DISTINCT Customer_ID)                     AS Unique_Customers,
    COUNT(DISTINCT Order_ID)                        AS Total_Orders,
    ROUND(SUM(Sales), 2)                            AS Total_Sales,
    ROUND(SUM(Profit), 2)                           AS Total_Profit,
    ROUND(SUM(Profit) * 100.0 / SUM(Sales), 2)     AS Margin_Pct,
    ROUND(AVG(Sales / Quantity), 2)                 AS Avg_Unit_Price
FROM superstore
GROUP BY Segment
ORDER BY Total_Profit DESC;
-- Query 7.2: Which segments buy which categories?
SELECT
    Segment,
    Category,
    ROUND(SUM(Sales), 2)    AS Total_Sales,
    ROUND(SUM(Profit), 2)   AS Total_Profit,
    COUNT(*)                AS Num_Orders
FROM superstore
GROUP BY Segment, Category
ORDER BY Segment, Total_Profit DESC;
-- Query 7.3: Top 10 most valuable customers
SELECT
    Customer_Name,
    Customer_ID,
    Segment,
    Region,
    COUNT(DISTINCT Order_ID)  AS Total_Orders,
    ROUND(SUM(Sales), 2)      AS Total_Spent,
    ROUND(SUM(Profit), 2)     AS Total_Profit_Generated
FROM superstore
GROUP BY Customer_Name, Customer_ID, Segment, Region
ORDER BY Total_Profit_Generated DESC
LIMIT 10;
-- Query 8.1: Create a summary view per order-line for Tableau
-- (This is what you export as superstore_enriched.csv)
SELECT
    Order_ID,
    Order_Date,
    STRFTIME('%Y', Order_Date)  AS Year,
    STRFTIME('%m', Order_Date)  AS Month,
    CASE
        WHEN CAST(STRFTIME('%m', Order_Date) AS INT) BETWEEN 1  AND 3  THEN 'Q1'
        WHEN CAST(STRFTIME('%m', Order_Date) AS INT) BETWEEN 4  AND 6  THEN 'Q2'
        WHEN CAST(STRFTIME('%m', Order_Date) AS INT) BETWEEN 7  AND 9  THEN 'Q3'
        ELSE 'Q4'
    END AS Quarter,
    Ship_Mode,
    Customer_ID,
    Customer_Name,
    Segment,
    State,
    Region,
    Category,
    Sub_Category,
    Product_Name,
    Sales,
    Quantity,
    Discount,
    ROUND(Discount * 100, 0)                AS Discount_Pct,
    Profit,
    ROUND(Profit * 100.0 / Sales, 2)        AS Profit_Margin_Pct,
    CASE
        WHEN Discount = 0         THEN '0%'
        WHEN Discount &lt;= 0.10     THEN '1-10%'
        WHEN Discount &lt;= 0.20     THEN '11-20%'
        WHEN Discount &lt;= 0.30     THEN '21-30%'
        ELSE '30%+'
    END AS Discount_Bucket,
    CASE
        WHEN Profit &gt; 0 THEN 'Profitable'
        WHEN Profit = 0 THEN 'Break Even'
        ELSE 'Loss'
    END AS Profit_Status
FROM superstore
ORDER BY Order_Date;</sql><current_tab id="0"/></tab_sql></sqlb_project>
